spring.application.name=LeatherMatch-AI

# ===========================================================================
# ONNX Model
# Adjust this path to where leather_model.onnx lives on your machine.
# ===========================================================================
onnx.model.path=C:/LeatherMatch/model/leather_model.onnx

# ===========================================================================
# Pattern database (JSON built by Python build_database.py)
# ===========================================================================
pattern.database.path=C:/LeatherMatch/data/pattern_database.json

# ===========================================================================
# Similarity matching
# ===========================================================================
similarity.threshold=0.70
similarity.margin=0.03

# ===========================================================================
# File upload limits
# ===========================================================================
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# ===========================================================================
# SQLite log database (plain JDBC - no JPA/Hibernate needed)
# ===========================================================================
sqlite.logs.path=C:/LeatherMatch/data/logs.db

# ===========================================================================
# Shared SQLite DataSource (HikariCP)
# ===========================================================================
spring.datasource.url=jdbc:sqlite:C:/LeatherMatch/data/logs.db
spring.datasource.driver-class-name=org.sqlite.JDBC
spring.datasource.hikari.maximum-pool-size=4
spring.datasource.hikari.connection-init-sql=PRAGMA journal_mode=WAL; PRAGMA foreign_keys=ON; PRAGMA busy_timeout=5000
spring.datasource.hikari.connection-timeout=10000

# ===========================================================================
# Server  (0.0.0.0 makes the API reachable from other LAN devices)
# ===========================================================================
server.port=8080
server.address=0.0.0.0

# ===========================================================================
# Authentication (HTTP Basic Auth)
# SECURITY: These credentials are REQUIRED and must be strong.
# - Passwords must be at least 12 characters
# - Common weak passwords (changeme123, operator123, etc.) are rejected
# - Application will NOT start if credentials are missing or weak (fail-fast)
# ===========================================================================
# Admin: full access to /api/admin/** and /api/match
admin.username=admin
admin.password=CHANGE_ME_TO_STRONG_PASSWORD_12_CHARS_MIN

# Operator: match-only (example user for /api/match, no admin access)
operator.username=operator
operator.password=CHANGE_ME_TO_STRONG_PASSWORD_12_CHARS_MIN

# ===========================================================================
# CORS (Cross-Origin Resource Sharing)
# SECURITY: Specify exact allowed origins (comma-separated, no wildcards)
# - Use http://localhost:PORT for local development
# - Use http://IP:PORT for LAN deployment
# - NEVER use wildcards (*) in production
# ===========================================================================
cors.allowed.origins=http://localhost:3000,http://localhost:5173,http://127.0.0.1:8080

# ===========================================================================
# SSL/TLS Configuration
# SECURITY: Set to true if using HTTPS (enables HSTS header)
# - Leave as false for HTTP-only LAN deployments
# ===========================================================================
server.ssl.enabled=false

# ===========================================================================
# Leather images storage root (reference images saved here by admin panel)
# ===========================================================================
leather.images.path=C:/LeatherMatch/Leather_Images

# ===========================================================================
# Feedback images (operator corrections pending admin review)
# ===========================================================================
feedback.images.path=C:/LeatherMatch/data/feedback_images

# ===========================================================================
# Admin SQLite path (shared database: match_logs + patterns + reference_images + settings)
# ===========================================================================
sqlite.admin.path=C:/LeatherMatch/data/logs.db

# ===========================================================================
# Logging
# ===========================================================================
logging.level.com.example=DEBUG
